# Set to "true" only when you want to connect to Firebase Emulator Suite.
# Default is disabled to avoid emulator-mode banners and accidental local/prod mixing.
VITE_USE_FIREBASE_EMULATORS=false

# GEMINI_API_KEY: Set to a placeholder for local development.
# If the app requires a real key to function, you'll need one from 
# https://aistudio.google.com/
GEMINI_API_KEY="local-dev-dummy-key"

# APP_URL: Use your local development server address.
# Usually Vite or Express defaults to 5173 or 3000.
APP_URL="http://localhost:5173"